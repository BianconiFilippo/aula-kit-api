// prisma/schema.prisma

generator client {
  provider  = "prisma-client-js"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

datasource db {
  provider = "postgresql"
}

enum EstadoClase {
  PENDIENTE
  COMPLETADA
  CANCELADA
}

model Usuario {
  id             String    @id @default(uuid())
  email          String    @unique
  nombreCompleto String?
  planActual     String    @default("gratis")
  materias       Materia[]
  createdAt      DateTime  @default(now())
}

model Materia {
  id           String              @id @default(uuid())
  nombre       String
  usuario      Usuario             @relation(fields: [usuarioId], references: [id])
  usuarioId    String
  carpetas     Carpeta[]
  fuentes      FuenteContenido[]
  generaciones GeneracionRecurso[]
  libroTemas   RegistroLibroTema[]
}

model Carpeta {
  id        String            @id @default(uuid())
  nombre    String
  materia   Materia           @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  materiaId String
  parent    Carpeta?          @relation("SubCarpetas", fields: [parentId], references: [id], onDelete: Cascade)
  parentId  String?
  hijos     Carpeta[]         @relation("SubCarpetas")
  fuentes   FuenteContenido[]
  createdAt DateTime          @default(now())
}

model RegistroLibroTema {
  id            String      @id @default(uuid())
  orden         Int
  fecha         DateTime
  titulo        String
  descripcion   String?     @db.Text
  estado        EstadoClase @default(PENDIENTE)
  unidad        String?
  caracter      String?
  dinamica      String?
  observaciones String?     @db.Text
  actividades   String?     @db.Text

  materia   Materia @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  materiaId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TipoContenido {
  PDF
  IMAGEN
  VIDEO
  PRESENTACION
  LINK_DRIVE
  TEXTO_PLANO
}

model FuenteContenido {
  id            String              @id @default(uuid())
  materia       Materia             @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  materiaId     String
  carpeta       Carpeta?            @relation(fields: [carpetaId], references: [id], onDelete: Cascade)
  carpetaId     String?
  tipo          TipoContenido
  urlArchivo    String? // URL de Supabase Storage
  nombreArchivo String?
  textoExtraido String?             @db.Text
  generaciones  GeneracionRecurso[]
  createdAt     DateTime            @default(now())
}

model GeneracionRecurso {
  id        String      @id @default(uuid())
  materiaId String
  tipo      TipoRecurso
  titulo    String
  contenido String      @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  materia           Materia          @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  fuenteContenido   FuenteContenido? @relation(fields: [fuenteContenidoId], references: [id])
  fuenteContenidoId String?
}

enum TipoRecurso {
  RESUMEN
  GUIA_ESTUDIO
  EVALUACION
  MAPA_CONCEPTUAL
}
