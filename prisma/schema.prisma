// prisma/schema.prisma

generator client {
  provider  = "prisma-client-js"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

datasource db {
  provider = "postgresql"
}

enum EstadoClase {
  PENDIENTE
  COMPLETADA
  CANCELADA
}

model Usuario {
  id                      String    @id @default(uuid())
  email                   String    @unique
  nombreCompleto          String?
  planActual              String    @default("gratis")
  tier                    String    @default("free")
  peticiones_ia_restantes Int       @default(3)
  fecha_ultimo_reinicio   DateTime?
  materias                Materia[]
  recordatorios           Recordatorio[]
  createdAt               DateTime  @default(now())
}

model Materia {
  id           String              @id @default(uuid())
  nombre       String
  usuario      Usuario             @relation(fields: [usuarioId], references: [id])
  usuarioId    String
  carpetas     Carpeta[]
  fuentes      FuenteContenido[]
  generaciones GeneracionRecurso[]
  libroTemas   RegistroLibroTema[]
  librosTemas  LibroTema[]
  recordatorios Recordatorio[]
}

model Carpeta {
  id        String            @id @default(uuid())
  nombre    String
  materia   Materia           @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  materiaId String
  parent    Carpeta?          @relation("SubCarpetas", fields: [parentId], references: [id], onDelete: Cascade)
  parentId  String?
  hijos     Carpeta[]         @relation("SubCarpetas")
  fuentes   FuenteContenido[]
  createdAt DateTime          @default(now())
}

model RegistroLibroTema {
  id            String      @id @default(uuid())
  orden         Int
  fecha         DateTime
  titulo        String
  descripcion   String?     @db.Text
  estado        EstadoClase @default(PENDIENTE)
  unidad        String?
  caracter      String?
  dinamica      String?
  observaciones String?     @db.Text
  actividades   String?     @db.Text

  materia   Materia @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  materiaId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TipoContenido {
  PDF
  IMAGEN
  VIDEO
  PRESENTACION
  LINK_DRIVE
  TEXTO_PLANO
}

model FuenteContenido {
  id            String              @id @default(uuid())
  materia       Materia             @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  materiaId     String
  carpeta       Carpeta?            @relation(fields: [carpetaId], references: [id], onDelete: Cascade)
  carpetaId     String?
  tipo          TipoContenido
  urlArchivo    String? // URL de Supabase Storage
  nombreArchivo String?
  textoExtraido String?             @db.Text
  generaciones  GeneracionRecurso[]
  createdAt     DateTime            @default(now())
}

model GeneracionRecurso {
  id        String      @id @default(uuid())
  materiaId String
  tipo      TipoRecurso
  titulo    String
  contenido String      @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  materia           Materia          @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  fuenteContenido   FuenteContenido? @relation(fields: [fuenteContenidoId], references: [id])
  fuenteContenidoId String?
}

enum TipoRecurso {
  RESUMEN
  GUIA_ESTUDIO
  EVALUACION
  MAPA_CONCEPTUAL
  CLASE
  PRESENTACION
}

enum TipoContenidoTema {
  conceptual
  procedimental
  actitudinal
  mixto
}

enum ModalidadClase {
  individual
  grupal
  plenario
  mixta
}

enum EstadoClaseNuevo {
  planificada
  dada
  cancelada
  postergada
}

enum Trimestre {
  T1 @map("1")
  T2 @map("2")
  T3 @map("3")
}

enum ColorUnidad {
  teal
  blue
  amber
  coral
  purple
  pink
  green
}

enum CapacidadMCC {
  oralidad
  pensamiento_critico
  resolucion_problemas
  trabajo_colaborativo
  tecnologias
  ed_ambiental
}

enum EvaluacionTema {
  observacion
  tp
  escrita
  oral
  sin_evaluacion
}

model LibroTema {
  id             String    @id @default(uuid())
  materiaId      String    @map("materia_id")
  cicloLectivo   Int       @map("ciclo_lectivo")
  cursoDivision  String    @map("curso_division")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  materia        Materia   @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  unidades       Unidad[]

  @@map("libros_temas")
}

model Unidad {
  id               String         @id @default(uuid())
  libroTemaId      String         @map("libro_tema_id")
  nombre           String
  trimestre        Trimestre
  semanasEstimadas Int            @map("semanas_estimadas")
  color            ColorUnidad
  objetivos        String?        @db.Text
  aprendizajePda   String?        @map("aprendizaje_pda") @db.Text
  metaCicloPda     String?        @map("meta_ciclo_pda") @db.Text
  capacidadesMcc   CapacidadMCC[] @map("capacidades_mcc")
  orden            Int
  
  libroTema        LibroTema      @relation(fields: [libroTemaId], references: [id], onDelete: Cascade)
  temas            Tema[]

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("unidades")
}

model Tema {
  id              String            @id @default(uuid())
  unidadId        String            @map("unidad_id")
  nombre          String
  tipoContenido   TipoContenidoTema @map("tipo_contenido")
  clasesEstimadas Int               @map("clases_estimadas")
  evaluacion      EvaluacionTema
  indicadorLogro  String?           @map("indicador_logro") @db.Text
  observaciones   String?           @db.Text
  orden           Int

  unidad          Unidad            @relation(fields: [unidadId], references: [id], onDelete: Cascade)
  clases          Clase[]

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@map("temas")
}

model Clase {
  id            String           @id @default(uuid())
  temaId        String           @map("tema_id")
  titulo        String
  fechaEstimada DateTime?        @map("fecha_estimada") @db.Date
  modalidad     ModalidadClase
  estado        EstadoClaseNuevo @default(planificada)
  novedades     String?          @db.Text
  orden         Int

  tema          Tema             @relation(fields: [temaId], references: [id], onDelete: Cascade)

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@map("clases")
}

model Recordatorio {
  id             String    @id @default(uuid())
  titulo         String
  contenido      String?   @db.Text
  fecha          DateTime  @db.Date
  color          String?   // e.g., 'blue', 'green', 'amber', 'purple', etc.
  usuarioId      String    @map("usuario_id")
  materiaId      String?   @map("materia_id")
  
  usuario        Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  materia        Materia?  @relation(fields: [materiaId], references: [id], onDelete: Cascade)

  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([usuarioId])
  @@index([materiaId])
  @@map("recordatorios")
}

